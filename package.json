{
  "name": "nav-online-invoice-mcp",
  "version": "1.0.0",
  "description": "MCP server for Hungarian NAV Online Invoice (Online Szamla) API v3.0",
  "main": "dist/index.js",
  "bin": {
    "nav-online-invoice-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --disable-proto=throw dist/cli.js",
    "dev": "tsx --node-options='--disable-proto=throw' src/cli.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "audit:check": "npm audit --audit-level=high"
  },
  "type": "module",
  "keywords": [
    "nav",
    "online-invoice",
    "online-szamla",
    "hungary",
    "tax",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "fast-xml-parser": "^5.2.0",
    "js-sha3": "^0.9.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
