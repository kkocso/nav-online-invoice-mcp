# NAV Online Invoice API credentials
# Get these from https://onlineszamla.nav.gov.hu/ (or test: https://onlineszamla-test.nav.gov.hu/)
NAV_LOGIN=your_technical_user_login
NAV_PASSWORD=your_technical_user_password
NAV_TAX_NUMBER=12345678
NAV_SIGNATURE_KEY=your_signature_key
NAV_EXCHANGE_KEY=your_exchange_key

# Environment: "test" or "production" (default: production)
NAV_ENV=test

# Optional: Override base URL
# NAV_BASE_URL=https://api-test.onlineszamla.nav.gov.hu/invoiceService/v3

# Software identification (optional, defaults provided)
# NAV_SOFTWARE_ID=NAVONLINEINVMCP01
# NAV_SOFTWARE_NAME=nav-online-invoice-mcp
# NAV_SOFTWARE_VERSION=1.0.0
# NAV_SOFTWARE_DEV_NAME=Your Name
# NAV_SOFTWARE_DEV_CONTACT=your@email.com
# NAV_SOFTWARE_DEV_COUNTRY=HU
# NAV_SOFTWARE_DEV_TAX_NUMBER=12345678
